# -*- coding: utf-8 -*-
# Marcus Platform Frontend Dockerfile
# 前端在本地预构建（npm run build），Docker 只复制 dist 到 nginx，省 Node.js 内存

FROM nginx:alpine

# Copy pre-built dist (built locally on dev machine)
COPY frontend/dist /usr/share/nginx/html

# Copy nginx config
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
