# ==========================================
# Marcus AI Trading Platform - Environment Config
# ==========================================
# Copy this file to .env and fill in your actual values

# API Keys (NEVER commit .env to version control)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_HOST=api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

TUSHARE_TOKEN=your_tushare_token_here

# Xueqiu Cookie Token
XUEQIU_TOKEN=xq_a_token=your_xueqiu_token_here

# Marcus Workspace Path (auto-detected if not set)
# MARCUS_WORKSPACE=/root/.openclaw/workspace-marcus
# MARCUS_WORKSPACE=F:/pythonProject/AITrade/workspace-marcus

# OS Detection for path (auto-detected if not set)
# MARCUS_OS=linux  (for WSL/Linux)
# MARCUS_OS=windows (for Windows)

# Database
DATABASE_URL=postgresql://marcus:password@localhost:5432/marcus_trading
REDIS_URL=redis://localhost:6379/0

# Server
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# QQ Bot (Official QQ Bot API)
QQ_APP_ID=your_qq_app_id
QQ_APP_SECRET=your_qq_app_secret
QQ_BOT_ENABLED=false
QQ_BOT_RECIPIENT=your_qq_openid

# Pi Server (Node.js AI Agent bridge)
PI_SERVER_URL=http://localhost:3001/chat

# Security
SECRET_KEY=generate_a_random_secret_key_here
